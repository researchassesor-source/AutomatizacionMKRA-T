# ==========================================================================
#  RA-Training - Motor de Automatizacion (MKRA-T)
#  Copia este archivo a ".env" y completa los valores. NUNCA subas ".env".
# ==========================================================================

# --- Base de datos (PostgreSQL) ---
# En Vercel + Neon estas dos variables se crean automaticamente al conectar la
# base de datos. En local, apunta ambas a tu Postgres (Docker: docker compose up -d db).
#   POSTGRES_PRISMA_URL      -> conexion con pooler (usa la app)
#   POSTGRES_URL_NON_POOLING -> conexion directa (usa db push / migraciones)
POSTGRES_PRISMA_URL="postgresql://mkra:mkra@localhost:5432/mkra?schema=public"
POSTGRES_URL_NON_POOLING="postgresql://mkra:mkra@localhost:5432/mkra?schema=public"

# --- App ---
APP_URL="http://localhost:3000"

# --- Panel de administracion ---
# Define una contrasena para HABILITAR el panel en /admin.
# Si se deja vacia, el panel queda deshabilitado (seguro por defecto).
ADMIN_PASSWORD=""

# --- Cron (Vercel Cron) ---
# Secreto para proteger los endpoints de cron (nurture/publicacion).
# Vercel envia "Authorization: Bearer <CRON_SECRET>" en sus llamadas.
CRON_SECRET=""

# --- Almacenamiento de imagenes (Vercel Blob) ---
# Para el boton "Subir imagen" del panel. Se crea automaticamente al conectar
# un store de Blob en Vercel (Storage -> Create -> Blob).
BLOB_READ_WRITE_TOKEN=""

# --- Meta (Instagram + Facebook) via Graph API ---
# https://developers.facebook.com/  (App -> Instagram Graph API / Pages)
META_APP_ID=""
META_APP_SECRET=""
META_PAGE_ID=""
META_IG_USER_ID=""
META_ACCESS_TOKEN=""

# --- WhatsApp Cloud API (opcional, fase de nurture) ---
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# --- Email transaccional (opcional, fase de nurture) ---
# Proveedor recomendado con buena entregabilidad (Resend, Postmark, SES...)
EMAIL_API_KEY=""
EMAIL_FROM="hola@ra-training.com"

# --- Integracion con ra-training-finance (fuente de verdad de certificados) ---
# FINANCE_API_URL: endpoint que acepta ?payload= (el /api/proxy de finance en
#   Vercel, o directamente la URL /exec del Apps Script).
FINANCE_API_URL=""
# FINANCE_APP_URL: base del sitio de finance, para los enlaces de verificacion.
FINANCE_APP_URL="https://finanzas.ra-training.com"
# Usuario de servicio en finance con rol "vendedor" (o "admin").
FINANCE_USER=""
FINANCE_PASS=""
# Servicio a inscribir en el handoff (debe existir en finance).
FINANCE_SERVICE_NAME="Certificado LMS"
# Emision del certificado: por defecto MANUAL (finance lo emite por su flujo).
# Pon "true" para que MKRA-T lo emita automaticamente al completar el curso
# (recomendado solo para cursos gratuitos de enganche).
FINANCE_AUTO_EMIT="false"
