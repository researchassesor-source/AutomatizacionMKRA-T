// Modelo de datos del motor de automatizacion de RA-Training.
// Cubre la base de la fase 1 (captacion de leads) y deja preparado
// el terreno para nurture y ventas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Catalogo de cursos (los gratuitos de enganche y, luego, los de pago) ---
model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description String?
  isFree      Boolean  @default(true)
  isPublished Boolean  @default(true)
  // Beneficios / bullets de la landing (JSON: string[])
  benefits    Json?
  // Duracion estimada, ej "3 horas"
  duration    String?
  // Menciona aval del Ministerio de Trabajo SOLO si esta gestionado legalmente
  hasCertificate Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads        Lead[]
  certificates Certificate[]

  @@map("courses")
}

// --- Lead / contacto (nucleo del CRM) ---
model Lead {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  // De donde vino: utm_source, campaña, etc.
  source    String?
  utmSource String?
  utmMedium String?
  utmCampaign String?

  // Etapa en el embudo de ventas
  stage     LeadStage @default(NUEVO)

  // Curso gratuito por el que entro
  course    Course?  @relation(fields: [courseId], references: [id])
  courseId  String?

  consent   Boolean  @default(false) // acepto tratamiento de datos
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events       LeadEvent[]
  messages     OutboundMessage[]
  certificates Certificate[]

  @@index([email])
  @@index([stage])
  @@map("leads")
}

enum LeadStage {
  NUEVO
  INSCRITO       // se registro al curso gratis
  EN_CURSO       // esta consumiendo el contenido
  CERTIFICADO    // termino y obtuvo certificado
  OPORTUNIDAD    // candidato a curso de pago
  CLIENTE        // compro
  PERDIDO
}

// --- Bitacora de interacciones de un lead (para scoring y automatizaciones) ---
model LeadEvent {
  id        String   @id @default(cuid())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  type      String   // ej "form_submit", "email_open", "course_complete"
  payload   Json?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("lead_events")
}

// --- Cuentas de redes sociales conectadas ---
model SocialAccount {
  id           String   @id @default(cuid())
  platform     SocialPlatform
  displayName  String
  externalId   String?  // page id / ig user id
  // Tokens: en produccion deben cifrarse o guardarse en un secret manager
  accessToken  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  posts SocialPost[]

  @@unique([platform, externalId])
  @@map("social_accounts")
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  YOUTUBE
  LINKEDIN
}

// --- Publicaciones programadas / orquestador de contenido ---
model SocialPost {
  id          String    @id @default(cuid())
  account     SocialAccount @relation(fields: [accountId], references: [id])
  accountId   String
  caption     String
  mediaUrl    String?
  linkUrl     String?
  status      PostStatus @default(BORRADOR)
  scheduledAt DateTime?
  publishedAt DateTime?
  externalPostId String?  // id devuelto por la red social
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@map("social_posts")
}

enum PostStatus {
  BORRADOR
  PROGRAMADO
  PUBLICANDO
  PUBLICADO
  FALLIDO
}

// --- Mensajes salientes (nurture: email / WhatsApp) ---
// Cada paso de una secuencia genera un OutboundMessage programado; un
// dispatcher (cron) los envia cuando llega su hora. Mismo patron que SocialPost.
model OutboundMessage {
  id          String   @id @default(cuid())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  channel     MessageChannel
  toAddress   String        // correo o telefono destino
  subject     String?
  body        String
  status      MessageStatus @default(PROGRAMADO)
  scheduledAt DateTime
  sentAt      DateTime?
  error       String?
  sequenceKey String?       // que secuencia lo genero, ej "bienvenida"
  stepKey     String?       // que paso, ej "acceso"
  createdAt   DateTime      @default(now())

  @@index([status, scheduledAt])
  @@index([leadId])
  @@map("outbound_messages")
}

enum MessageChannel {
  EMAIL
  WHATSAPP
}

enum MessageStatus {
  PROGRAMADO
  ENVIANDO
  ENVIADO
  FALLIDO
  OMITIDO
}

// --- Certificados / constancias con folio verificable ---
model Certificate {
  id          String   @id @default(cuid())
  folio       String   @unique // codigo publico, ej "RA-2026-A1B2C3"
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  course      Course   @relation(fields: [courseId], references: [id])
  courseId    String
  holderName  String   // nombre en el certificado (snapshot)
  courseTitle String   // titulo del curso (snapshot al momento de emitir)
  // Si el curso tiene aval oficial gestionado; se congela al emitir
  official    Boolean  @default(false)
  issuedAt    DateTime @default(now())
  revoked     Boolean  @default(false)

  @@unique([leadId, courseId]) // un certificado por lead+curso
  @@index([folio])
  @@map("certificates")
}
